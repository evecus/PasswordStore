<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.PasswordManager" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <!-- 平滑的 Activity 转场动画 -->
        <item name="android:windowAnimationStyle">@style/Animation.Activity</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.PasswordManager.Dialog</item>
    </style>

    <style name="Theme.PasswordManager.NoActionBar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.PasswordManager.Dialog</item>
    </style>

    <!-- 弹窗主题:圆角卡片 + 主题色按钮,与全局配色统一 -->
    <style name="ThemeOverlay.PasswordManager.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.PasswordManager.Dialog</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.PasswordManager.Dialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.PasswordManager.Dialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.PasswordManager.Dialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.PasswordManager.Dialog.Button</item>
    </style>

    <style name="ShapeAppearance.PasswordManager.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="TextAppearance.PasswordManager.Dialog.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">19sp</item>
    </style>

    <style name="TextAppearance.PasswordManager.Dialog.Body" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.PasswordManager.Dialog.Button" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Activity 淡入淡出转场 -->
    <style name="Animation.Activity" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/activity_fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/activity_fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/activity_fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/activity_fade_out</item>
    </style>
</resources>
